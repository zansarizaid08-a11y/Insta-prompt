<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AI Prompt Hub - Premium</title>
    
    <script type='text/javascript' src='//pl25750104.effectivegatecpm.com/c6/e7/7f/c6e77f5c1efceb275ad6696551624641.js'></script>

    <style>
        :root {
            --primary: #4f46e5;
            --secondary: #3b82f6;
            --bg-dark: #0f172a;
            --card-bg: #1e293b;
            --text-main: #f8fafc;
            --text-muted: #94a3b8;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Segoe UI', sans-serif; }
        body { background-color: var(--bg-dark); color: var(--text-main); line-height: 1.5; }

        nav {
            display: flex; justify-content: space-between; align-items: center;
            padding: 1rem 5%; background: #0f172a; border-bottom: 1px solid #334155;
            position: sticky; top: 0; z-index: 1000;
        }
        .logo { font-weight: bold; font-size: 1.2rem; display: flex; align-items: center; gap: 10px; }
        .logo img { width: 32px; height: 32px; border-radius: 50%; }

        .category-wrapper {
            position: sticky; top: 65px; z-index: 999;
            background: #0f172a; padding: 12px 0;
            border-bottom: 1px solid #334155;
        }
        .category-scroll {
            display: flex; gap: 10px; overflow-x: auto;
            padding: 0 5%; scrollbar-width: none;
        }
        .category-scroll::-webkit-scrollbar { display: none; }
        
        .cat-btn {
            background: #1e293b; color: white; border: 1px solid #334155;
            padding: 7px 18px; border-radius: 20px; font-size: 0.85rem;
            white-space: nowrap; cursor: pointer; transition: 0.3s;
        }
        .cat-btn.active { background: white; color: black; border-color: white; font-weight: bold; }

        .container { max-width: 1000px; margin: 0 auto; padding: 15px; }
        header { text-align: center; padding: 1rem 0; }
        h1 { font-size: 2rem; margin-bottom: 1rem; color: #a5b4fc; font-weight: 700; }

        .search-container { display: flex; gap: 8px; margin-bottom: 20px; max-width: 600px; margin: auto; }
        input[type="text"] { 
            flex: 1; padding: 12px; border-radius: 10px; border: 1px solid #334155; 
            background: #1e293b; color: white; outline: none;
        }
        .search-btn { background: var(--secondary); color: white; border: none; padding: 0 20px; border-radius: 10px; cursor: pointer; }

        .trending-link {
            background:#ef4444; color:white; padding:10px 18px; 
            border-radius:8px; text-decoration:none; font-weight:bold; 
            font-size:0.8rem; display: inline-block; margin-bottom: 10px;
        }

        #results-area {
            display: grid; grid-template-columns: repeat(2, 1fr); 
            gap: 15px; margin-top: 10px;
        }

        .prompt-card { 
            background: var(--card-bg); border-radius: 15px; overflow: hidden; 
            display: flex; flex-direction: column; border: 1px solid #334155;
        }
        .image-box { position: relative; width: 100%; aspect-ratio: 1/1; }
        .image-box img { width: 100%; height: 100%; object-fit: cover; }
        .video-label { 
            position: absolute; top: 8px; left: 8px; background: rgba(0,0,0,0.7); 
            color: #ff4d4d; border: 1px solid #ff4d4d; padding: 2px 6px; 
            border-radius: 4px; font-size: 9px; font-weight: bold; 
        }

        .content-box { padding: 10px; }
        .prompt-title { font-size: 0.8rem; color: var(--text-muted); margin-bottom: 10px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

        .btn-group { display: flex; gap: 5px; }
        .btn-card { 
            flex: 1; padding: 8px 2px; border-radius: 6px; border: none; 
            font-size: 0.7rem; font-weight: 700; cursor: pointer; text-align: center;
            text-decoration: none; color: white;
        }
        .copy-btn { background: #334155; }
        .watch-btn { background: var(--secondary); }

        .native-ad-container {
            grid-column: span 2;
            width: 100%;
            margin: 15px 0;
            text-align: center;
        }

        #toast { 
            position: fixed; bottom: 30px; left: 50%; transform: translateX(-50%); 
            background: #10b981; color: white; padding: 10px 20px; 
            border-radius: 50px; display: none; z-index: 2000;
        }

        @media (max-width: 600px) { h1 { font-size: 1.6rem; } #results-area { gap: 10px; } }
    </style>
</head>
<body>

<nav>
    <div class="logo">
        <img src="https://i.ibb.co/m5pXz1D/instagram-logo.png" alt="Logo"> AI PROMPT HUB
    </div>
    <div style="font-size: 1.5rem; cursor: pointer;">&#9776;</div>
</nav>

<div class="category-wrapper">
    <div class="category-scroll" id="cat-list">
        <button class="cat-btn active" onclick="filterData('All', this)">All</button>
    </div>
</div>

<div class="container">
    <header>
        <h1>Discover Premium Prompts</h1>
        <div class="search-container">
            <input type="text" id="search-input" placeholder="Search prompts...">
            <button class="search-btn" onclick="handleSearch()">Search</button>
        </div>
        <a href="https://www.effectivegatecpm.com/z5q9i3x45w?key=06adf9977ec69fdce5fef572556a5d88" target="_blank" class="trending-link">
            🔥 TRENDING AI TOOLS (2026)
        </a>
    </header>

    <div id="results-area"></div>
</div>

<div id="toast">Copied to Clipboard!</div>

<script>
    let db = [];

    async function init() {
        try {
            const res = await fetch('./database.json');
            if(res.ok) { db = await res.json(); }
            createCategoryButtons();
            renderData(db);
        } catch (e) { console.error("Error loading database"); }
    }

    function createCategoryButtons() {
        const catList = document.getElementById('cat-list');
        const categories = [...new Set(db.map(item => item.category).filter(c => c))];
        categories.forEach(cat => {
            const btn = document.createElement('button');
            btn.className = 'cat-btn';
            btn.innerText = cat;
            btn.onclick = (e) => filterData(cat, e.target);
            catList.appendChild(btn);
        });
    }

    function filterData(category, btn) {
        document.querySelectorAll('.cat-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        const filtered = (category === 'All') ? db : db.filter(item => item.category === category);
        renderData(filtered);
    }

    function insertNativeAd(targetArea) {
        const adDiv = document.createElement('div');
        adDiv.className = 'native-ad-container';
        const containerId = 'container-15b9c32f55639f994ab49336ecb3dd5c';
        adDiv.id = containerId;
        targetArea.appendChild(adDiv);

        const script = document.createElement('script');
        script.async = true;
        script.setAttribute('data-cfasync', 'false');
        script.src = `//pl28750234.effectivegatecpm.com/15b9c32f55639f994ab49336ecb3dd5c/invoke.js`;
        adDiv.appendChild(script);
    }

    // UPDATED: Random Data Rendering Function
    function renderData(list) {
        const area = document.getElementById('results-area');
        area.innerHTML = '';
        
        let cardCount = 0;
        let adInserted = false;
        const allItems = [];

        // Database se saara data extract karke ek list mein daalna
        list.forEach(user => {
            user.data.forEach(item => {
                allItems.push({user, item});
            });
        });

        if (allItems.length === 0) return;

        // --- RANDOM SHUFFLE LOGIC (Fisher-Yates) ---
        for (let i = allItems.length - 1; i > 0; i--) {
            const j = Math.floor(Math.random() * (i + 1));
            [allItems[i], allItems[j]] = [allItems[j], allItems[i]];
        }

        // Shuffled data ko render karna
        allItems.forEach((entry) => {
            const {user, item} = entry;
            const card = document.createElement('div');
            card.className = 'prompt-card';
            card.innerHTML = `
                <div class="image-box">
                    <span class="video-label">▶ REEL</span>
                    <img src="${item.image}" loading="lazy">
                </div>
                <div class="content-box">
                    <div class="prompt-title">/ prompt-text</div>
                    <div class="btn-group">
                        <button class="btn-card copy-btn" onclick="copyText(\`${item.prompt}\`)">Copy</button>
                        <a href="${user.instagram}" target="_blank" class="btn-card watch-btn">Watch</a>
                    </div>
                </div>
            `;
            area.appendChild(card);
            cardCount++;

            if (cardCount === 2 && !adInserted) {
                insertNativeAd(area);
                adInserted = true;
            }
        });

        if (cardCount < 2 && !adInserted) {
            insertNativeAd(area);
            adInserted = true;
        }
    }

    function handleSearch() {
        const val = document.getElementById('search-input').value.toLowerCase();
        const filtered = db.filter(u => 
            u.instagram.toLowerCase().includes(val) || 
            u.data.some(d => d.prompt.toLowerCase().includes(val))
        );
        renderData(filtered);
    }

    function copyText(txt) {
        navigator.clipboard.writeText(txt);
        const t = document.getElementById('toast');
        t.style.display = 'block';
        setTimeout(() => t.style.display = 'none', 2000);
    }

    window.onload = init;
</script>

</body>
</html>
